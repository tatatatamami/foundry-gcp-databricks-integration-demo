# Databricks (Google Cloud)
# Databricks workspace のホスト名。 例: <workspace-id>.2.gcp.databricks.com
DATABRICKS_HOST=<your-databricks-host>.gcp.databricks.com

# Databricks SQL Warehouse ID
DATABRICKS_WAREHOUSE_ID=<your-warehouse-id>

# 実行時に入力する場合は不要。環境変数で渡す場合のみ設定する
# DATABRICKS_PAT=<your-personal-access-token>

# Azure AI Foundry
# Foundry プロジェクトの API エンドポイント
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project>

# Azure OpenAI (Foundry 経由の場合は Cognitive Services エンドポイント)
AZURE_OPENAI_ENDPOINT=https://<your-foundry-account>.cognitiveservices.azure.com/

# Azure AI Search
AZURE_SEARCH_SERVICE=<your-search-service-name>
AZURE_SEARCH_RESOURCE_GROUP=<your-resource-group>

# Azure ML
AZURE_ML_WORKSPACE=<your-aml-workspace-name>

# 既定の同期元テーブル (検証2・3)
DATABRICKS_SOURCE_TABLE=<catalog>.<schema>.<table>
